# ── Required ──────────────────────────────────────────────────────────────────
# Ethereum RPC endpoint (e.g. Alchemy, Infura, or your own node)
RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID

# Bot wallet private key — NEVER commit this file with a real key
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Morpho Vault V2 address to manage
VAULT_ADDRESS=0xYOUR_VAULT_ADDRESS_HERE

# The single MorphoMarketV1AdapterV2 deployed for the above vault.
# All vault.allocate / vault.deallocate calls use this adapter; only the
# ABI-encoded MarketParams in the call data varies per market.
# Verify via: vault.adaptersAt(0) — or deploy via MorphoMarketV1AdapterV2Factory.
ADAPTER_ADDRESS=0xYOUR_ADAPTER_ADDRESS_HERE

# Path to the JSON file listing the Morpho Blue markets the bot manages.
# Shape: { "markets": [{ "label", "marketParams": { loanToken, collateralToken, oracle, irm, lltv } }] }
# See managed-markets.example.json for the expected format.
# Caps (absoluteCap / relativeCap) are configured on-chain by the curator — not stored here.
MANAGED_MARKETS_PATH=./managed-markets.json

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZ

# Telegram chat ID where alerts are sent (use @userinfobot to find yours)
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ── Optional — defaults shown ──────────────────────────────────────────────────
# Cron schedule for rebalance checks (default: every 5 minutes)
# CRON_SCHEDULE=*/5 * * * *

# Minimum drift in basis points before a rebalance is triggered (default: 500 = 5%)
# DRIFT_THRESHOLD_BPS=500

# Maximum gas price in gwei — skip execution if exceeded (default: 50)
# GAS_CEILING_GWEI=50

# Minimum ETH wallet balance for gas; alert if below this threshold (default: 0.05)
# MIN_ETH_BALANCE=0.05

# HTTP port for the Fastify server (default: 3000)
# PORT=3000

# Dry run mode — log proposed actions without submitting transactions (default: false)
# DRY_RUN=false

# Maximum allocation to any single market as a percentage of that market's total supply (default: 10)
# MAX_MARKET_CONCENTRATION_PCT=10

# Minimum available liquidity multiplier — reject markets with liquidity < N × allocation (default: 2)
# MIN_LIQUIDITY_MULTIPLIER=2
