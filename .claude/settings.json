      "Bash(tee:*)",
      "mcp__stitch__build_site",
      "mcp__stitch__get_screen_code",
      "mcp__stitch__get_screen_image",
      "mcp__paper__get_basic_info",
      "mcp__paper__get_selection",
      "mcp__paper__get_node_info",
