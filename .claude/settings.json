      "mcp__paper__get_fill_image",
      "mcp__paper__get_font_family_info",
      "mcp__paper__get_guide",
      "mcp__paper__get_tree_summary",
      "mcp__paper__write_html",
      "mcp__paper__create_artboard",
      "mcp__paper__delete_nodes",
      "mcp__paper__set_text_content",
      "mcp__paper__rename_nodes",
      "mcp__paper__update_styles",
      "mcp__paper__duplicate_nodes",
      "mcp__paper__finish_working_on_nodes",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Read(/**/*)",
      "Write(/**/*)",
      "Edit(/**/*)",
      "Read(.claude/**)",
      "Write(.claude/**)",
      "Edit(.claude/**)",
      "Read(.claude/**/*)",
      "Write(.claude/**/*)",
      "Edit(.claude/**/*)",
      "WebSearch(*)",
      "WebFetch(*)"
    ],
    "deny": []
  },
  "enabledMcpjsonServers": ["stitch"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/no-main-branch.sh" }]
      },
      {
        "matcher": "Write",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/no-secrets.sh" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "bash .claude/hooks/no-debug.sh" }]
      }
    ]
  }
}